# Use Python 3.13 alpine image for smaller size
FROM python:3.13-alpine

ARG REQUIREMENTS_HASH=initial
RUN echo "Building purge worker with requirements hash: $REQUIREMENTS_HASH"

WORKDIR /app

COPY ./var/requirements-purge-worker.txt ./

RUN pip install --no-cache-dir -r requirements-purge-worker.txt

COPY pyproject.toml /app/pyproject.toml
COPY src/ ./ 

ENV PYTHONPATH=/app

EXPOSE 8008

CMD ["python", "-m", "models.workers.purge.purge_worker"]