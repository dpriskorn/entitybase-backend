# Use Python 3.13 alpine image for smaller size
FROM python:3.13-alpine

ARG REQUIREMENTS_HASH=initial
RUN echo "Building with requirements hash: $REQUIREMENTS_HASH"

WORKDIR /app

COPY ../var/requirements-stats-worker.txt ./

RUN pip install --no-cache-dir -r requirements-stats-worker.txt

COPY pyproject.toml /app/pyproject.toml
COPY src/ ./ 

ENV PYTHONPATH=/app

EXPOSE 8004 8005 8006

CMD ["python", "-m", "models.workers.backlink_statistics.backlink_statistics_worker"]
